# Modelo de variáveis de ambiente.
# 1. Copie este arquivo e renomeie a cópia para ".env"
# 2. Substitua o valor abaixo pela sua chave da API do Gemini
#    (gere a sua em: https://aistudio.google.com/apikey)
#
# IMPORTANTE: o arquivo .env (com a chave real) NÃO deve ser enviado ao GitHub.

API_GEMINI_KEY=cole_sua_chave_do_gemini_aqui
